<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CyberCops Academy — Secure Assessment Framework</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" type="image/jpeg" href="/logo.jpeg">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind = {
      config: {
        theme: {
          extend: {
            fontFamily: { sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'sans-serif'] },
            colors: {
              brand: { 50: '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe', 300: '#a5b4fc', 400: '#818cf8', 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca', 800: '#3730a3', 900: '#312e81', 950: '#1e1b4b' },
              slate: { 850: '#172033' }
            },
            boxShadow: {
              soft: "0 20px 60px -24px rgba(15, 23, 42, 0.25)",
              glow: "0 0 40px -12px rgba(79, 70, 229, 0.35)",
            },
          },
        },
      },
    };
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/htmx.min.js" defer></script>
</head>
<body class="antialiased">
  <div class="pointer-events-none fixed inset-0 bg-[radial-gradient(ellipse_at_15%_50%,_rgba(99,102,241,0.06),_transparent_50%),radial-gradient(ellipse_at_85%_50%,_rgba(79,70,229,0.04),_transparent_50%)]"></div>

  <div id="global-loader" class="fixed inset-0 z-50 hidden items-center justify-center bg-surface-950/25 px-4 backdrop-blur-sm">
    <div class="flex items-center gap-3 rounded-2xl border border-white/50 bg-white/90 px-5 py-4 shadow-lg">
      <div class="h-5 w-5 animate-spin rounded-full border-2 border-brand-600 border-t-transparent"></div>
      <div class="text-sm font-medium text-surface-700">Loading</div>
    </div>
  </div>

  <div class="relative mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
    <header class="no-print relative overflow-hidden rounded-2xl border border-brand-800/40 bg-slate-850 px-6 py-5 text-white shadow-lg sm:px-8" style="background: linear-gradient(135deg, #1e1b4b 0%, #172033 50%, #0f172a 100%);">
      <div class="absolute inset-0 opacity-20">
        <div class="absolute inset-0" style="background: radial-gradient(circle at 20% 40%, rgba(99,102,241,0.4), transparent 50%)"></div>
        <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 70%, rgba(79,70,229,0.3), transparent 45%)"></div>
      </div>
      <div class="relative flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-center gap-4">
          <img src="/logo.jpeg" alt="CyberCops Academy" class="h-12 w-12 rounded-xl object-cover ring-2 ring-brand-400/40 shadow-lg flex-shrink-0">
          <div>
            <div class="flex items-center gap-3">
              <h1 class="text-2xl font-bold tracking-tight sm:text-3xl text-white">CyberCops Academy</h1>
              <span class="rounded-full bg-brand-500/20 text-brand-300 px-3 py-0.5 text-[10px] font-bold uppercase tracking-widest border border-brand-400/30">v1.0</span>
            </div>
            <p class="text-sm text-slate-300 mt-0.5">Secure candidate testing, course management, and certification platform</p>
          </div>
        </div>
        <div class="flex gap-2">
          <button
            class="nav-btn inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/10 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20 hover:text-white shadow-sm"
            data-nav="portal"
            hx-get="/portal"
            hx-target="#main"
            hx-swap="innerHTML"
            hx-indicator="#global-loader"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
            Candidate Portal
          </button>
          <button
            class="nav-btn inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-semibold text-slate-300 transition hover:bg-white/10 hover:text-white"
            data-nav="admin"
            hx-get="/admin"
            hx-target="#main"
            hx-swap="innerHTML"
            hx-indicator="#global-loader"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Administration
          </button>
        </div>
      </div>
    </header>

    <section class="grid gap-4 sm:grid-cols-3">
      <div class="premium-card">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-surface-500">Platform Metrics</p>
            <p class="mt-0.5 text-xs text-surface-400">Total assessments completed</p>
            <p class="mt-2 text-3xl font-bold tracking-tight text-surface-900"><%= attemptCounter %></p>
          </div>
          <div class="rounded-xl bg-brand-50 p-3 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
        </div>
      </div>
      <div class="premium-card">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-surface-500">Exam Duration</p>
            <p class="mt-0.5 text-xs text-surface-400">Configured time limit</p>
            <p class="mt-2 text-3xl font-bold tracking-tight text-surface-900"><%= examDurationMinutes %><span class="text-lg font-medium text-surface-400 ml-1">min</span></p>
          </div>
          <div class="rounded-xl bg-brand-50 p-3 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
        </div>
      </div>
      <div class="premium-card">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-surface-500">System Status</p>
            <p class="mt-0.5 text-xs text-surface-400">Server-backed session storage</p>
            <div class="flex items-center gap-2 mt-3">
              <span class="h-3 w-3 rounded-full bg-emerald-500 animate-pulse"></span>
              <span class="text-lg font-bold text-surface-900">Live</span>
            </div>
          </div>
          <div class="rounded-xl bg-emerald-50 p-3 text-emerald-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>
          </div>
        </div>
      </div>
    </section>

    <main id="main" class="relative min-h-[42rem] rounded-2xl border border-surface-200 bg-white/95 p-5 shadow-lg backdrop-blur-sm sm:p-8">
      <%- include("partials/portal", { courses, examDurationMinutes }) %>
    </main>
  </div>

  <script src="/app.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CyberCops Academy - Secure Quiz Framework & Management System</title>
  <script>
    tailwind = {
      config: {
        theme: {
          extend: {
            boxShadow: {
              soft: "0 20px 60px -24px rgba(15, 23, 42, 0.25)"
            }
          }
        }
      }
    };
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/htmx.min.js" defer></script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-700 antialiased">
  <div class="pointer-events-none fixed inset-0 bg-[radial-gradient(circle_at_top,_rgba(14,165,233,0.08),_transparent_45%),linear-gradient(to_bottom,rgba(248,250,252,1),rgba(241,245,249,1))]"></div>

  <div id="global-loader" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/25 px-4 backdrop-blur-sm">
    <div class="flex items-center gap-3 rounded-2xl border border-white/50 bg-white/90 px-5 py-4 shadow-soft">
      <div class="h-5 w-5 animate-spin rounded-full border-2 border-sky-600 border-t-transparent"></div>
      <div class="text-sm font-medium text-slate-700">Loading</div>
    </div>
  </div>

  <div class="relative mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
    <header class="overflow-hidden rounded-3xl border border-slate-200/80 bg-slate-950 px-6 py-6 text-white shadow-soft sm:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-sky-300">CyberCops Academy</p>
          <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Assessment System & Administrative Console</h1>
          <p class="max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
            Secure candidate testing, course management, and certificate-style result reporting in one server-backed workspace.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <button
            class="nav-btn rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/20"
            data-nav="portal"
            hx-get="/portal"
            hx-target="#main"
            hx-swap="innerHTML"
            hx-indicator="#global-loader"
          >
            Candidate Portal
          </button>
          <button
            class="nav-btn rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:bg-white/15"
            data-nav="admin"
            hx-get="/admin"
            hx-target="#main"
            hx-swap="innerHTML"
            hx-indicator="#global-loader"
          >
            Administration
          </button>
        </div>
      </div>
    </header>

    <section class="grid gap-4 sm:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Platform Metrics</div>
        <div class="mt-2 text-sm text-slate-500">Total assessment attempts processed</div>
        <div class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= attemptCounter %></div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Exam Duration</div>
        <div class="mt-2 text-sm text-slate-500">Configured time limit</div>
        <div class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= examDurationMinutes %> min</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Current State</div>
        <div class="mt-2 text-sm text-slate-500">Server-backed session and storage</div>
        <div class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Live</div>
      </div>
    </section>

    <main id="main" class="relative min-h-[42rem] rounded-3xl border border-slate-200 bg-white/95 p-5 shadow-soft backdrop-blur-sm sm:p-8">
      <%- include("partials/portal", { courses, examDurationMinutes }) %>
    </main>
  </div>

  <script src="/app.js"></script>
</body>
</html>

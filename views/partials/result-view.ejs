<section class="space-y-6 animate-fade-in">
  <div class="flex flex-wrap items-center justify-end gap-3 no-print">
    <button class="premium-btn premium-btn-primary" onclick="window.print()">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
      Export PDF Report
    </button>
    <button class="premium-btn premium-btn-ghost" hx-get="/portal" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      New Attempt
    </button>
  </div>

  <div class="mx-auto max-w-3xl">
    <div class="relative overflow-hidden rounded-2xl border-8 border-double border-surface-900 bg-white p-8 shadow-2xl sm:p-12 print:border-4">
      <div class="absolute inset-0 opacity-[0.02] pointer-events-none">
        <div class="absolute inset-0" style="background: repeating-linear-gradient(45deg, transparent, transparent 8px, #000 8px, #000 9px)"></div>
      </div>

      <div class="relative text-center">
        <div class="mb-5 inline-flex items-center gap-2 rounded-full bg-surface-100 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-surface-600">
          Official Assessment Report
        </div>

        <div class="mb-6">
          <span class="<%= attempt.passed ? 'inline-block rounded-xl bg-emerald-50 px-8 py-3 text-2xl font-black uppercase tracking-widest text-emerald-700 border-2 border-emerald-500 shadow-lg' : 'inline-block rounded-xl bg-rose-50 px-8 py-3 text-2xl font-black uppercase tracking-widest text-rose-700 border-2 border-rose-500' %>">
            STATUS: <%= attempt.passed ? "PASS" : "FAIL" %>
          </span>
        </div>

        <div class="flex items-center justify-center gap-3 mb-2">
          <img src="/logo.jpeg" alt="CyberCops Academy" class="h-12 w-12 rounded-xl object-cover ring-2 ring-brand-200 shadow-md">
          <h2 class="text-3xl font-bold text-surface-900 sm:text-4xl tracking-tight">CyberCops Academy</h2>
        </div>
        <p class="text-sm text-surface-500 font-medium">Validation Standard Certification</p>

        <div class="mx-auto mt-8 max-w-md">
          <table class="w-full text-left text-sm">
            <tbody class="divide-y divide-surface-100">
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500 w-[40%]">Participant</th>
                <td class="py-3 text-right font-semibold text-surface-900"><%= attempt.candidateName %></td>
              </tr>
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500">Institution</th>
                <td class="py-3 text-right text-surface-700"><%= attempt.institution %></td>
              </tr>
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500">Assessment Track</th>
                <td class="py-3 text-right text-surface-700 font-medium"><%= attempt.course.code %>: <%= attempt.course.name %></td>
              </tr>
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500">Score</th>
                <td class="py-3 text-right font-bold text-surface-900 text-base"><%= attempt.rawScore %> / <%= attempt.totalQuestions %></td>
              </tr>
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500">Percentage</th>
                <td class="py-3 text-right font-bold text-surface-900 text-lg"><%= Number(attempt.percentage).toFixed(1) %>%</td>
              </tr>
              <tr>
                <th class="py-3 pr-4 text-xs font-bold uppercase tracking-wider text-surface-500">Timeline</th>
                <td class="py-3 text-right text-xs text-surface-500 leading-relaxed"><%= attempt.startedAt.toLocaleString("en-GB") %><br><%= attempt.endedAt ? attempt.endedAt.toLocaleString("en-GB") : "" %></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mx-auto mt-8 max-w-md rounded-xl border border-surface-200 bg-surface-50 p-5 text-left">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <p class="text-xs font-bold uppercase tracking-wider text-surface-500">Authentication Signature</p>
            </div>
            <button onclick="copySignature()" class="premium-btn premium-btn-ghost text-xs px-3 py-1.5" title="Copy to clipboard">
              <svg id="copy-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              <span id="copy-label">Copy</span>
            </button>
          </div>
          <p id="signature-text" class="break-all font-mono text-xs text-surface-600 bg-white rounded-lg p-3 border border-surface-100 select-all"><%= attempt.checksum || "" %></p>
          <div class="mt-3 flex items-center justify-between">
            <p class="text-xs italic text-surface-400">Verified at runtime. Content integrity enforced server-side.</p>
            <a href="/verify" target="_blank" class="text-xs font-semibold text-brand-600 hover:text-brand-700 underline transition">Verify Online</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function copySignature() {
  const text = document.getElementById('signature-text');
  if (!text || !text.textContent) return;
  navigator.clipboard.writeText(text.textContent.trim()).then(() => {
    const icon = document.getElementById('copy-icon');
    const label = document.getElementById('copy-label');
    icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
    label.textContent = 'Copied!';
    setTimeout(() => {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
      label.textContent = 'Copy';
    }, 2000);
  }).catch(() => {
    const range = document.createRange();
    range.selectNodeContents(text);
    const selection = window.getSelection();
    selection.removeAllRanges();
    selection.addRange(range);
  });
}
</script>
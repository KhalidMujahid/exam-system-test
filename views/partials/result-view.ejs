<section class="space-y-6">
  <div class="flex flex-wrap items-center justify-end gap-3 print:hidden">
    <button
      class="rounded-full bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-100"
      onclick="window.print()"
    >
      Export Result Summary (PDF)
    </button>
    <button
      class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
      hx-get="/portal"
      hx-target="#main"
      hx-swap="innerHTML"
      hx-indicator="#global-loader"
    >
      New Attempt
    </button>
  </div>

  <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft sm:p-8 print:border-0 print:shadow-none">
    <div class="mx-auto max-w-4xl">
      <div class="mb-6 flex justify-center">
        <div class="<%= attempt.passed ? 'border-emerald-500 bg-emerald-50 text-emerald-700' : 'border-rose-500 bg-rose-50 text-rose-700' %> rounded-full border px-4 py-2 text-sm font-semibold">
          STATUS: <%= attempt.passed ? "PASS" : "FAIL" %>
        </div>
      </div>

      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Official Assessment Report</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900">CyberCops Academy Validation Standard</h2>
      </div>

      <div class="mt-8 overflow-hidden rounded-3xl border border-slate-200">
        <table class="w-full border-collapse text-left">
          <tbody class="divide-y divide-slate-200">
            <tr class="bg-slate-50">
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Participant Name</th>
              <td class="px-5 py-4 text-sm text-slate-900"><%= attempt.candidateName %></td>
            </tr>
            <tr>
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Institution / Organisation</th>
              <td class="px-5 py-4 text-sm text-slate-900"><%= attempt.institution %></td>
            </tr>
            <tr class="bg-slate-50">
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Assessment Track</th>
              <td class="px-5 py-4 text-sm text-slate-900"><%= attempt.course.code %>: <%= attempt.course.name %></td>
            </tr>
            <tr>
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Quantitative Score</th>
              <td class="px-5 py-4 text-sm font-semibold text-slate-900"><%= attempt.rawScore %> / <%= attempt.totalQuestions %></td>
            </tr>
            <tr class="bg-slate-50">
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Evaluation Percentage</th>
              <td class="px-5 py-4 text-sm font-semibold text-slate-900"><%= Number(attempt.percentage).toFixed(1) %>%</td>
            </tr>
            <tr>
              <th class="w-1/3 px-5 py-4 text-sm font-semibold text-slate-700">Session Timeline Logs</th>
              <td class="px-5 py-4 text-sm text-slate-900"><%= attempt.startedAt.toLocaleString("en-GB") %> | <%= attempt.endedAt ? attempt.endedAt.toLocaleString("en-GB") : "" %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-5 text-sm text-slate-600">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">System Authentication Signature Block</div>
        <div class="mt-2 font-mono text-xs text-slate-700"><%= attempt.checksum || "" %></div>
      </div>
    </div>
  </div>
</section>

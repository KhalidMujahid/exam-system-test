<section class="mx-auto max-w-lg space-y-5 animate-fade-in">
  <div class="premium-alert premium-alert-error">
    <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <div>
      <div class="text-sm font-bold">Registration Error</div>
      <div class="mt-1 text-sm"><%= message %></div>
    </div>
  </div>
  <button class="premium-btn premium-btn-secondary" hx-get="/portal" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Back to registration
  </button>
</section>
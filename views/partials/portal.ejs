<section class="space-y-8">
  <div class="flex flex-col gap-2 border-b border-surface-200 pb-5">
    <p class="text-xs font-bold uppercase tracking-widest text-brand-600">Candidate Workflow</p>
    <h2 class="text-2xl font-bold tracking-tight text-surface-900">Participant Registration &amp; Track Selection</h2>
    <p class="max-w-3xl text-sm text-surface-500 leading-relaxed">
      Register a candidate, choose a course, and start a timed assessment session backed by the database.
    </p>
  </div>

  <form
    id="registration-form"
    class="space-y-6"
    hx-post="/quiz"
    hx-target="#main"
    hx-swap="innerHTML"
    hx-indicator="#global-loader"
  >
    <div class="grid gap-5 md:grid-cols-2">
      <div class="space-y-2">
        <label for="reg-name" class="premium-label">Full Name</label>
        <input type="text" name="name" id="reg-name" placeholder="e.g. Inspector John Smith" class="premium-input" autocomplete="name" />
      </div>
      <div class="space-y-2">
        <label for="reg-inst" class="premium-label">Institution / Organisation</label>
        <input type="text" name="institution" id="reg-inst" placeholder="e.g. Metropolitan Police Service" class="premium-input" autocomplete="organization" />
      </div>
    </div>

    <div class="space-y-3">
      <div class="flex items-end justify-between gap-4">
        <label class="premium-label mb-0">Select Assessment Track</label>
        <div class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
          <span><%= courses.length %></span>
          <span>tracks available</span>
        </div>
      </div>

      <div class="grid gap-3 lg:grid-cols-2">
        <% courses.forEach(function(course, index) { %>
          <label class="premium-option-label group">
            <input type="radio" name="courseId" value="<%= course.id %>" <%= index === 0 ? "checked" : "" %> class="premium-radio" />
            <span class="flex-1 min-w-0">
              <span class="block text-sm font-semibold text-surface-900"><%= course.code %> — <%= course.name %></span>
              <span class="block text-xs text-surface-400 mt-0.5"><%= course._count.questions %> questions loaded</span>
            </span>
            <svg class="h-4 w-4 flex-shrink-0 text-surface-300 mt-0.5 group-has-[:checked]:text-brand-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
      <div class="flex items-start gap-2.5 text-sm text-surface-500">
        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>20 randomly selected questions. <strong class="text-surface-700">80% passing threshold</strong>. Timer starts on initialization.</span>
      </div>
      <button class="premium-btn premium-btn-primary" type="submit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Initialize Assessment
      </button>
    </div>
  </form>

  <div class="border-t border-surface-200 pt-6">
    <p class="text-xs font-bold uppercase tracking-widest text-brand-600 mb-4">Course Materials</p>
    <div class="grid gap-3" id="materials-list">
      <% courses.forEach(function(course) { %>
        <div class="premium-card premium-card-flat">
          <div class="flex items-center justify-between gap-3">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-surface-900"><%= course.code %> — <%= course.name %></p>
              <p class="text-xs text-surface-400 mt-0.5">Study materials and course resources</p>
            </div>
            <button
              class="premium-btn premium-btn-ghost text-xs"
              type="button"
              onclick="loadMaterials('<%= course.id %>', this)"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              Browse Materials
            </button>
          </div>
          <div class="mt-3 hidden materials-dropdown space-y-2" data-course-id="<%= course.id %>">
            <div class="text-xs text-surface-400 text-center py-4">Loading materials...</div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="border-t border-surface-200 pt-6">
    <div class="premium-card premium-card-flat flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="rounded-xl bg-brand-50 p-2.5 text-brand-600">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-surface-900">Verify a Certificate</p>
          <p class="text-xs text-surface-400">Authenticate an assessment report using its signature</p>
        </div>
      </div>
      <button class="premium-btn premium-btn-primary text-sm" hx-get="/verify" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Verify Now
      </button>
    </div>
  </div>
</section>

<script>
function loadMaterials(courseId, btn) {
  const dropdown = document.querySelector(`.materials-dropdown[data-course-id="${courseId}"]`);
  if (!dropdown) return;
  dropdown.classList.toggle('hidden');
  if (dropdown.classList.contains('hidden')) return;
  dropdown.innerHTML = '<div class="text-xs text-surface-400 text-center py-4"><div class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-brand-600 border-t-transparent mr-2"></div>Loading...</div>';
  fetch(`/materials/${courseId}`)
    .then(r => r.json())
    .then(data => {
      if (data.length === 0) {
        dropdown.innerHTML = '<div class="text-xs text-surface-400 text-center py-4">No materials uploaded yet.</div>';
        return;
      }
      dropdown.innerHTML = data.map(m => `
        <a href="${m.url}" target="_blank" class="flex items-center gap-3 rounded-lg border border-surface-200 bg-white px-3 py-2.5 text-sm hover:bg-brand-50 hover:border-brand-300 transition group">
          <svg class="h-4 w-4 text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <span class="flex-1 min-w-0">
            <span class="block text-surface-900 font-medium truncate">${m.title}</span>
            <span class="block text-xs text-surface-400">${(m.filesize / 1024).toFixed(0)} KB</span>
          </span>
          <svg class="h-4 w-4 text-surface-300 group-hover:text-brand-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>
      `).join('');
    })
    .catch(() => {
      dropdown.innerHTML = '<div class="text-xs text-rose-500 text-center py-4">Failed to load materials.</div>';
    });
}
</script>
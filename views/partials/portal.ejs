<section class="space-y-8">
  <div class="flex flex-col gap-2 border-b border-slate-200 pb-5">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700">Candidate Workflow</p>
    <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Participant Registration & Track Selection</h2>
    <p class="max-w-3xl text-sm text-slate-600">
      Register a candidate, choose a course, and start a timed assessment session backed by the database.
    </p>
  </div>

  <form
    id="registration-form"
    class="space-y-5"
    action="/quiz"
    method="post"
    hx-post="/quiz"
    hx-target="#main"
    hx-swap="innerHTML"
    hx-indicator="#global-loader"
  >
    <div class="grid gap-5 md:grid-cols-2">
      <div class="space-y-2">
        <label for="reg-name" class="text-sm font-semibold text-slate-800">Full Name</label>
        <input
          type="text"
          name="name"
          id="reg-name"
          placeholder="e.g. Inspector John Smith"
          class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
          autocomplete="name"
        />
      </div>

      <div class="space-y-2">
        <label for="reg-inst" class="text-sm font-semibold text-slate-800">Institution / Organisation</label>
        <input
          type="text"
          name="institution"
          id="reg-inst"
          placeholder="e.g. Metropolitan Police Service"
          class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
          autocomplete="organization"
        />
      </div>
    </div>

    <div class="space-y-3">
      <div class="flex items-end justify-between gap-4">
        <label class="text-sm font-semibold text-slate-800">Select Core Target Assessment Course</label>
        <div class="text-xs text-slate-500"><%= courses.length %> tracks available</div>
      </div>

      <div class="grid gap-3 lg:grid-cols-2">
        <% courses.forEach(function(course, index) { %>
          <label class="group flex cursor-pointer items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-sky-300 hover:bg-sky-50">
            <input
              type="radio"
              name="courseId"
              value="<%= course.id %>"
              <%= index === 0 ? "checked" : "" %>
              class="mt-1 h-4 w-4 border-slate-300 text-sky-600 focus:ring-sky-500"
            />
            <span class="space-y-1">
              <span class="block text-sm font-semibold text-slate-900"><%= course.code %> - <%= course.name %></span>
              <span class="block text-xs text-slate-500"><%= course._count.questions %> questions loaded</span>
            </span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
      <p class="text-sm text-slate-500">The session timer starts as soon as the assessment opens.</p>
      <button
        class="rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-100"
        type="submit"
      >
        Initialize Assessment Session
      </button>
    </div>
  </form>
</section>

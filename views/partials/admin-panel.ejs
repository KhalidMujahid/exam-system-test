<section class="space-y-8 animate-fade-in">
  <div class="flex flex-col gap-4 border-b border-surface-200 pb-5 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-1">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-600">Administration Console</p>
      <h2 class="text-2xl font-bold tracking-tight text-surface-900">System Administration</h2>
      <p class="text-sm text-surface-500 max-w-2xl">Update credentials, manage tracks, edit question pools, upload course materials, and keep the runtime boundary under control.</p>
    </div>
    <form hx-post="/admin/logout" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
      <button class="premium-btn premium-btn-ghost" type="submit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Lock Session
      </button>
    </form>
  </div>

  <%- include("admin-stats", { attemptCounter, examDurationMinutes }) %>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="premium-card premium-card-flat">
      <h3 class="text-base font-bold text-surface-900">Update Admin Password</h3>
      <form class="mt-4" hx-post="/admin/password" hx-target="#admin-message" hx-swap="innerHTML" hx-indicator="#global-loader">
        <div class="flex flex-col gap-3 sm:flex-row">
          <input type="password" name="password" placeholder="Enter new password" class="premium-input min-w-0 flex-1" />
          <button class="premium-btn premium-btn-primary whitespace-nowrap" type="submit">Update Secret</button>
        </div>
      </form>
      <div id="admin-message" class="mt-4"></div>
    </div>

    <div class="premium-card premium-card-flat">
      <h3 class="text-base font-bold text-surface-900">Global Assessment Duration</h3>
      <form class="mt-4" hx-post="/admin/duration" hx-target="#admin-stats" hx-swap="innerHTML" hx-indicator="#global-loader">
        <div class="flex flex-col gap-3 sm:flex-row">
          <input type="number" name="minutes" min="1" max="180" value="<%= examDurationMinutes %>" class="premium-input min-w-0 flex-1" />
          <button class="premium-btn premium-btn-secondary whitespace-nowrap" type="submit">Save</button>
        </div>
      </form>
    </div>
  </div>

  <div class="premium-card">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h3 class="text-base font-bold text-surface-900">Course Matrix Configuration</h3>
        <p class="text-sm text-surface-500 mt-0.5">Rename tracks, add new ones, or reload question pools for a selected course.</p>
      </div>
      <form hx-post="/admin/attempts/reset" hx-target="#admin-stats" hx-swap="innerHTML" hx-indicator="#global-loader">
        <button class="premium-btn premium-btn-danger" type="submit">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Reset Counter
        </button>
      </form>
    </div>

    <div class="mt-5 space-y-3">
      <% courses.forEach(function(course) { %>
        <form class="grid gap-3 rounded-xl border border-surface-200 bg-surface-50 p-4 lg:grid-cols-[1fr_2fr_auto]" hx-post="/admin/courses" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
          <input type="hidden" name="originalCode" value="<%= course.code %>" />
          <input type="text" name="code" value="<%= course.code %>" class="premium-input" />
          <input type="text" name="name" value="<%= course.name %>" class="premium-input" />
          <button class="premium-btn premium-btn-secondary" type="submit">Save</button>
        </form>
      <% }) %>
    </div>

    <form class="mt-4 grid gap-3 rounded-xl border border-dashed border-surface-300 bg-surface-50 p-4 lg:grid-cols-[1fr_2fr_auto]" hx-post="/admin/courses" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
      <input type="text" name="code" placeholder="New course code" class="premium-input" />
      <input type="text" name="name" placeholder="New course title" class="premium-input" />
      <button class="premium-btn premium-btn-primary" type="submit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Course
      </button>
    </form>
  </div>

  <!-- Course Materials Section -->
  <div class="premium-card">
    <div class="flex flex-col gap-3 border-b border-surface-200 pb-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h3 class="text-base font-bold text-surface-900">Course Materials Library</h3>
        <p class="text-sm text-surface-500 mt-0.5">Upload PDFs, documents, and resources for students to download per track.</p>
      </div>
      <form hx-get="/admin" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
        <label class="sr-only" for="matCourseId">Select course</label>
        <select id="matCourseId" name="courseId" class="premium-select" onchange="this.form.requestSubmit()">
          <% courses.forEach(function(course) { %>
            <option value="<%= course.id %>" <%= selectedCourse && selectedCourse.id === course.id ? "selected" : "" %>><%= course.code %> — <%= course.name %></option>
          <% }) %>
        </select>
      </form>
    </div>

    <form class="mt-4 flex flex-col gap-4 sm:flex-row sm:items-end" hx-post="/admin/materials/upload" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader" enctype="multipart/form-data">
      <input type="hidden" name="courseId" value="<%= selectedCourse ? selectedCourse.id : "" %>" />
      <div class="flex-1 space-y-2 min-w-0">
        <label class="premium-label">Material Title</label>
        <input type="text" name="title" placeholder="e.g. Chapter 1 - Introduction" class="premium-input" />
      </div>
      <div class="flex-1 space-y-2 min-w-0">
        <label class="premium-label">File (PDF, DOC, etc.)</label>
        <input type="file" name="file" class="premium-input file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:font-semibold file:text-xs file:px-3 file:py-1.5 file:cursor-pointer hover:file:bg-brand-100 transition" />
      </div>
      <button class="premium-btn premium-btn-primary whitespace-nowrap" type="submit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
        Upload Material
      </button>
    </form>

    <% if (selectedCourse && selectedCourse.materials && selectedCourse.materials.length > 0) { %>
      <div class="mt-5 space-y-2">
        <% selectedCourse.materials.forEach(function(mat) { %>
          <div class="flex items-center gap-3 rounded-xl border border-surface-200 bg-white px-4 py-3">
            <div class="rounded-lg bg-brand-50 p-2 text-brand-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-surface-900 truncate"><%= mat.title %></p>
              <p class="text-xs text-surface-400"><%= (mat.filesize / 1024).toFixed(0) %> KB</p>
            </div>
            <div class="flex gap-2 flex-shrink-0">
              <a href="/materials/download/<%= mat.id %>" class="premium-btn premium-btn-ghost text-xs px-3 py-2">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              </a>
              <form hx-post="/admin/materials/delete/<%= mat.id %>" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader" class="inline">
                <button class="premium-btn premium-btn-danger text-xs px-3 py-2" type="submit">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else if (selectedCourse) { %>
      <p class="mt-5 text-sm text-surface-400 text-center py-6 border-2 border-dashed border-surface-200 rounded-xl">No materials uploaded for this course yet.</p>
    <% } %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="premium-card">
      <div class="flex items-start justify-between gap-4 border-b border-surface-200 pb-4 flex-wrap">
        <div class="min-w-0 flex-1">
          <h3 class="text-base font-bold text-surface-900">Question Ingestion Console</h3>
          <p class="text-sm text-surface-500 mt-0.5">Edit or replace the question pool for a selected track.</p>
        </div>
        <form class="flex-shrink-0" hx-get="/admin" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
          <label class="sr-only" for="courseId">Select course</label>
          <select id="courseId" name="courseId" class="premium-select" onchange="this.form.requestSubmit()">
            <% courses.forEach(function(course) { %>
              <option value="<%= course.id %>" <%= selectedCourse && selectedCourse.id === course.id ? "selected" : "" %>><%= course.code %> — <%= course.name %></option>
            <% }) %>
          </select>
        </form>
      </div>

      <form class="mt-4 space-y-4" hx-post="/admin/questions" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
        <input type="hidden" name="courseId" value="<%= selectedCourse ? selectedCourse.id : "" %>" />
        <textarea name="payload" rows="16" class="w-full rounded-xl border border-surface-300 bg-surface-950 px-4 py-4 font-mono text-sm leading-6 text-green-300 outline-none transition placeholder:text-surface-600 focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10 resize-y"><%= selectedCourse ? JSON.stringify(selectedCourse.questions.map(q => ({
          Question_ID: q.questionId,
          Question_Text: q.text,
          Option_A: q.optionA,
          Option_B: q.optionB,
          Option_C: q.optionC,
          Option_D: q.optionD,
          Correct_Answer: q.correctAnswer
        })), null, 2) : "[]" %></textarea>

        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="text-sm text-surface-500">Fields: <code class="text-xs bg-surface-100 px-1.5 py-0.5 rounded font-mono">Question_ID</code>, <code class="text-xs bg-surface-100 px-1.5 py-0.5 rounded font-mono">Question_Text</code>, <code class="text-xs bg-surface-100 px-1.5 py-0.5 rounded font-mono">Option_A</code>–<code class="text-xs bg-surface-100 px-1.5 py-0.5 rounded font-mono">D</code>, <code class="text-xs bg-surface-100 px-1.5 py-0.5 rounded font-mono">Correct_Answer</code></p>
          <div class="flex flex-wrap gap-3">
            <button class="premium-btn premium-btn-primary" type="submit">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/></svg>
              Commit Payload
            </button>
            <button class="premium-btn premium-btn-secondary" type="button" hx-post="/admin/questions/reset" hx-include="[name='courseId']" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Reset to Seeds
            </button>
          </div>
        </div>
      </form>
    </div>

    <div class="premium-card premium-card-flat">
      <h3 class="text-base font-bold text-surface-900">System Telemetry</h3>
      <p class="text-sm text-surface-500 mt-0.5">Current course capacities and runtime settings.</p>
      <div class="mt-4 space-y-2.5">
        <% courses.forEach(function(course) { %>
          <div class="rounded-xl border border-surface-200 bg-white px-4 py-3 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <div class="text-sm font-semibold text-surface-900"><%= course.code %></div>
              <div class="text-xs text-surface-500 truncate"><%= course.name %></div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-sm font-bold text-surface-900"><%= course._count.questions %></span>
              <span class="text-xs text-surface-400">q's</span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
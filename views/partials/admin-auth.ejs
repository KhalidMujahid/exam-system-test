<section class="mx-auto max-w-xl space-y-6">
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700">Administration Access</p>
    <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Administrative Access Challenge</h2>
    <p class="text-sm text-slate-600">Authenticate to edit tracks, manage settings, and review runtime telemetry.</p>
  </div>

  <% if (error) { %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"><%= error %></div>
  <% } %>

  <form class="space-y-4" hx-post="/admin/login" hx-target="#main" hx-swap="innerHTML" hx-indicator="#global-loader">
    <div class="space-y-2">
      <label for="admin-auth-pass" class="text-sm font-semibold text-slate-800">Console Secret Password Code</label>
      <input
        type="password"
        id="admin-auth-pass"
        name="password"
        placeholder="Enter password (Default: admin123)"
        class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
      />
    </div>

    <button class="rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-100" type="submit">
      Verify Credentials
    </button>
  </form>
</section>

<div class="grid gap-4 sm:grid-cols-2">
  <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Attempt Counter</div>
    <div class="mt-2 text-sm text-slate-500">Lifetime assessment submissions</div>
    <div class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= attemptCounter %></div>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Assessment Duration</div>
    <div class="mt-2 text-sm text-slate-500">Configured time limit</div>
    <div class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= examDurationMinutes %> min</div>
  </div>
</div>

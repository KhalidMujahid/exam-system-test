<section class="space-y-6">
  <div class="sticky top-4 z-10 rounded-2xl border border-brand-200 bg-white/95 px-6 py-4 shadow-lg backdrop-blur-md" data-timer-root>
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-bold uppercase tracking-widest text-surface-500">Active Candidate</p>
        <h2 class="mt-1 text-lg font-bold tracking-tight text-surface-900 truncate">
          <%= attempt.candidateName %>
          <span class="font-normal text-surface-500">(<%= attempt.institution %>)</span>
        </h2>
        <p class="mt-0.5 text-sm text-surface-500 truncate"><%= course.code %> — <%= course.name %></p>
      </div>

      <div class="flex items-center gap-5 flex-shrink-0">
        <div class="hidden sm:block w-44">
          <div class="flex items-center justify-between text-xs text-surface-500 mb-1.5">
            <span class="font-semibold">Progress</span>
            <span class="font-semibold" id="quiz-progress-text">0 of <%= questions.length %></span>
          </div>
          <div class="premium-progress">
            <div id="quiz-progress-bar" class="premium-progress-fill" style="width: 0%"></div>
          </div>
        </div>

        <div id="timer-container" class="premium-timer" data-timer-root>
          <div class="premium-timer-label">Time Remaining</div>
          <div class="premium-timer-value" data-seconds="<%= durationMinutes * 60 %>" data-attempt-id="<%= attempt.id %>">
            <span id="timer-display"><%= String(durationMinutes).padStart(2, "0") %>:00</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <form
    id="quiz-form"
    class="space-y-5"
    hx-post="/attempts/<%= attempt.id %>/submit"
    hx-target="#main"
    hx-swap="innerHTML"
    hx-indicator="#global-loader"
    data-question-count="<%= questions.length %>"
  >
    <div class="grid gap-4">
      <% questions.forEach(function(question, index) { %>
        <article class="premium-card premium-card-hover">
          <div class="mb-4 flex items-start justify-between gap-4">
            <div>
              <div class="flex items-center gap-3 mb-1">
                <span class="inline-flex items-center justify-center h-7 w-7 rounded-lg bg-brand-100 text-brand-700 text-xs font-bold">Q<%= index + 1 %></span>
                <span class="text-xs font-mono text-surface-400"><%= question.questionId %></span>
              </div>
              <h3 class="text-base font-semibold text-surface-900 leading-relaxed"><%= question.text %></h3>
            </div>
          </div>

          <div class="grid gap-2.5">
            <% [
              { key: "optionA", value: question.optionA },
              { key: "optionB", value: question.optionB },
              { key: "optionC", value: question.optionC },
              { key: "optionD", value: question.optionD }
            ].sort(() => Math.random() - 0.5).forEach(function(option) { %>
              <label class="premium-option-label">
                <input type="radio" name="answers[<%= question.id %>]" value="<%= option.value %>" class="premium-radio" onchange="updateQuizProgress()" />
                <span class="text-sm leading-relaxed text-surface-700"><%= option.value %></span>
              </label>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="flex items-center justify-between gap-4 rounded-2xl border border-surface-200 bg-surface-50 p-5">
      <div class="flex items-center gap-2 text-sm text-surface-500">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span>Review your answers before submitting. Submission finalises the session.</span>
      </div>
      <button class="premium-btn premium-btn-secondary" type="submit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Submit Answers
      </button>
    </div>
  </form>
</section>

<script>
  function updateQuizProgress() {
    const form = document.getElementById('quiz-form');
    if (!form) return;
    const radios = form.querySelectorAll('input[type="radio"]');
    const total = <%= questions.length %>;
    let answered = 0;
    radios.forEach(function(radio) { if (radio.checked) answered++; });
    const bar = document.getElementById('quiz-progress-bar');
    const text = document.getElementById('quiz-progress-text');
    if (bar) bar.style.width = (total > 0 ? (answered / total) * 100 : 0) + '%';
    if (text) text.textContent = answered + ' of ' + total;
  }
  document.addEventListener('htmx:afterSwap', function() { updateQuizProgress(); });
</script>